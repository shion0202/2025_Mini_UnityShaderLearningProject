{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "e0574c4f17b54ef3ac94a81cc1a6a7e7",
    "m_Title": "사칙연산",
    "m_Content": "Add: 두 값을 더한다.\nSubstract: 두 값을 뺀다.\nMultiply: 두 값을 곱한다.\nDivide: 두 값을 나눈다. (연산이 느려 꼭 필요한 경우가 아니면 사용하지 않는다.)\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1190.0,
        "y": -1059.0,
        "width": 426.0,
        "height": 107.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

